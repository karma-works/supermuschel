; supermuschel seatbelt profile — generated by SeatbeltBackend, do not edit
(version 1)
(deny default)

; ── Reads ─────────────────────────────────────────────────────────────────────
; Allow reading everything. The security boundary is WRITE access, not reads.
; Agents need full read to explore codebases, load system libraries, query git
; history, run linters, and resolve language runtimes (nvm/volta/asdf/etc.).
; Enumerating specific read paths causes SIGABRT crashes when a path does not
; exist on the system (e.g. ~/.nvm on a Volta user's machine).
(allow file-read* (subpath "/"))

; ── Writes ────────────────────────────────────────────────────────────────────
; Agents may only write to:
;   • the project directory (their workspace)
;   • /tmp and /private/tmp (sockets, pipes, lock files — /tmp is a symlink)
;   • /private/var/folders — where macOS $TMPDIR actually resolves
;   • {{TMPDIR}} — the exact $TMPDIR value injected at spawn time
;   • ~/.claude — Claude Code's own config and conversation history
(allow file-write*
  (subpath "{{PROJECT_PATH}}")
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/private/var/folders")
  (subpath "{{TMPDIR}}")
  (subpath "{{HOME_PATH}}/.claude"))

; ── Execution ─────────────────────────────────────────────────────────────────
; Allow executing any existing binary — agents run git, compilers, formatters,
; test runners, etc. Write restrictions prevent planting malicious binaries,
; so exec of pre-existing system binaries is safe.
(allow process-exec (subpath "/"))
(allow process-fork)
(allow signal)

; ── Networking ────────────────────────────────────────────────────────────────
(allow network*)

; ── Mach & system services ────────────────────────────────────────────────────
(allow mach-lookup)
(allow mach-register)
(allow mach-task-name)
(allow mach-priv-task-port)

; ── File operations ───────────────────────────────────────────────────────────
(allow file-ioctl)
(allow file-read-metadata)
(allow file-read-xattr)

; ── Sysctl ────────────────────────────────────────────────────────────────────
(allow sysctl-read)
(allow sysctl-write)

; ── IOKit (needed by Node.js / macOS security framework) ──────────────────────
(allow iokit-open)
(allow iokit-get-properties)

; ── POSIX IPC ─────────────────────────────────────────────────────────────────
(allow ipc-posix-shm*)

; ── Sockets ───────────────────────────────────────────────────────────────────
(allow system-socket)
