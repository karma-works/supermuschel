{
  "name": "supermuschel",
  "private": true,
  "packageManager": "bun@1.3.6",
  "workspaces": ["apps/*", "packages/*", "tools/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "db:migrate": "turbo run db:migrate --filter=desktop",
    "postinstall": "chmod +x node_modules/.bun/node-pty@1.1.0/node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
