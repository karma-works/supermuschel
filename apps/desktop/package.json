{
  "name": "@supermuschel/desktop",
  "version": "0.1.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:cli": "cd ../../tools/supermuschel-cli && bun run build && mkdir -p ../../apps/desktop/resources/bin && cp dist/supermuschel ../../apps/desktop/resources/bin/supermuschel",
    "dist": "bun run build && electron-builder",
    "dist:mac": "bun run build && electron-builder --mac",
    "preview": "electron-vite preview",
    "build:web": "vite build --config vite.web.config.mts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx electron/db/migrate.ts",
    "rebuild": "electron-rebuild -f -w node-pty,better-sqlite3"
  },
  "build": {
    "appId": "ai.supermuschel.desktop",
    "productName": "Supermuschel",
    "copyright": "Copyright © 2026 Supermuschel contributors",
    "asar": true,
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Supermuschel",
      "contents": [
        { "x": 410, "y": 150, "type": "link", "path": "/Applications" },
        { "x": 130, "y": 150, "type": "file" }
      ]
    },
    "linux": {
      "target": [
        { "target": "tar.gz", "arch": ["x64"] }
      ],
      "category": "Development",
      "icon": "resources/icon.svg",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "supermuschel",
      "repo": "supermuschel"
    }
  },
  "dependencies": {
    "@supermuschel/agent-api": "workspace:*",
    "@supermuschel/core": "workspace:*",
    "@supermuschel/sandbox": "workspace:*",
    "@supermuschel/shared": "workspace:*",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^11.6.0",
    "drizzle-orm": "^0.38.3",
    "electron-trpc": "^0.7.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-router": "^1.95.3",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@tanstack/react-query": "^5.64.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.30.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.0",
    "jotai": "^2.10.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "xterm": "^5.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0"
  }
}
